rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function userData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    // "admin" = admin de escuela; "superadmin" = administra toda la organización. Ambos pueden escribir.
    function isAdmin() { return signedIn() && (userData().role == 'admin' || userData().role == 'superadmin'); }
    function isSuperadmin() { return signedIn() && userData().role == 'superadmin'; }
    function myPlayerId() { return signedIn() ? userData().playerId : null; }
    // Un admin de escuela solo gestiona docs de SU misma org+escuela; el superadmin, cualquiera.
    function canManageSchool(data) { return isSuperadmin() || (isAdmin() && userData().orgId == data.orgId && userData().schoolId == data.schoolId); }

    // Perfiles de cuenta (rol + jugador vinculado). El uid del doc = uid de Firebase Auth.
    match /users/{uid} {
      allow read: if signedIn();
      // Al registrarse, cada uno crea su propio perfil pero NO puede nacer admin.
      // El admin sí puede crear perfiles de otros (p. ej. designar otro admin).
      allow create: if isAdmin() || (request.auth.uid == uid && request.resource.data.role == 'player');
      // Uno puede editar su propio perfil sin tocar rol ni jugador vinculado; el admin puede todo.
      allow update: if isAdmin() ||
        (request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.playerId == resource.data.playerId);
      allow delete: if isAdmin();
    }

    // Índice usuario→email (lectura pública: se necesita para loguear por usuario sin estar logueado).
    match /usernames/{uname} {
      allow read: if true;
      allow create: if isAdmin() || (signedIn() && request.resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // Jugadores: lectura para usuarios logueados; escritura del propio jugador (su perfil) o de un
    // admin de SU misma escuela (el superadmin, cualquiera). Un admin de otra escuela no puede tocarlo.
    // org/escuela son campos NATIVOS del doc; los jugadores viejos sin esos campos se "grandfatherean"
    // (cualquier admin puede editarlos hasta que se vuelvan a guardar y queden scopeados).
    // Invitados (schoolId == 'guest'): pertenecen a la org, no a una escuela → los gestiona cualquier admin de esa org.
    function pOwned(data) { return canManageSchool(data) || (isAdmin() && data.schoolId == 'guest' && userData().orgId == data.orgId) || (isAdmin() && !('orgId' in data)); }
    match /players/{id} {
      allow read: if signedIn();
      allow create: if pOwned(request.resource.data) || myPlayerId() == id;  // alta por admin de la escuela o autoregistro (su propio doc)
      allow update: if pOwned(resource.data) || myPlayerId() == id;
      allow delete: if pOwned(resource.data);
    }

    // Gimnasios: cada admin gestiona solo los de SU escuela (org/escuela nativos, con grandfather
    // para los gimnasios viejos sin esos campos, igual que players/tournaments).
    function gOwned(data) { return canManageSchool(data) || (isAdmin() && (!('orgId' in data) || data.orgId == null)); }
    match /gyms/{id} {
      allow read: if signedIn();
      allow create: if gOwned(request.resource.data);
      allow update, delete: if gOwned(resource.data);
    }
    // Noticias: lectura para logueados (los borradores se filtran en la app); solo admin escribe.
    match /news/{id}   { allow read: if signedIn(); allow write: if isAdmin(); }
    // Ajustes (incluye el tema): lectura pública para poder pintar la apariencia publicada en
    // la pantalla de inicio sin estar logueado. No hay datos sensibles (colores + toggles).
    match /app/{doc}   { allow read: if true; allow write: if isAdmin(); }

    // Torneos: solo el admin de la MISMA escuela del torneo (o superadmin), o un colaborador
    // (su playerId está en collaborators), pueden editarlo. Un admin de otra escuela no.
    // org/escuela son campos NATIVOS del doc (los escribe la app/Worker). Los torneos viejos que
    // todavía no los tienen se "grandfatherean": cualquier admin puede editarlos hasta que se vuelvan
    // a guardar (ahí ganan los campos y quedan scopeados). El otorgar puntos cross-escuela y la
    // auto-inscripción pasan por el Worker (que saltea reglas).
    function tOwned(data) { return canManageSchool(data) || (isAdmin() && !('orgId' in data)); }
    match /tournaments/{id} {
      allow read: if signedIn();
      allow create: if tOwned(request.resource.data);
      // El dueño/superadmin puede todo. Un colaborador puede editar el torneo PERO NO cambiar la lista
      // de colaboradores (no puede auto-promover ni sacar a otros): collaborators debe quedar igual.
      allow update: if tOwned(resource.data)
        || (signedIn() && myPlayerId() in resource.data.collaborators
            && request.resource.data.collaborators == resource.data.collaborators);
      allow delete: if tOwned(resource.data);
    }

    // Cuentas de cobro (MercadoPago): el token es SECRETO. Solo el admin dueño puede leer/escribir
    // las suyas (las consultas de la app van scopeadas por ownerUid). Los jugadores no acceden.
    // El backend (Cloudflare Worker) usa el Admin SDK y saltea estas reglas para crear el pago.
    match /payAccounts/{id} {
      allow read:   if isAdmin() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAdmin() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAdmin() && resource.data.ownerUid == request.auth.uid;
    }

    // Historial de pagos (PII: email/monto del pagador). Lo escribe SOLO el backend (Worker, vía
    // cuenta de servicio, que saltea reglas). Lectura SCOPEADA: superadmin todo, admin solo su escuela,
    // jugador solo sus propios pagos. Los campos orgId/schoolId/playerId los escribe el Worker nativos.
    match /payments/{id} {
      allow read: if canManageSchool(resource.data) || (signedIn() && resource.data.playerId == myPlayerId());
      allow write: if false;
    }
  }
}
