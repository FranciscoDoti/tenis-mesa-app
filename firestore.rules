rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function userData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    // "admin" = admin de escuela; "superadmin" = administra toda la organización. Ambos pueden escribir.
    function isAdmin() { return signedIn() && (userData().role == 'admin' || userData().role == 'superadmin'); }
    function isSuperadmin() { return signedIn() && userData().role == 'superadmin'; }
    function myPlayerId() { return signedIn() ? userData().playerId : null; }
    // Un admin de escuela solo gestiona docs de SU misma org+escuela; el superadmin, cualquiera.
    function canManageSchool(data) { return isSuperadmin() || (isAdmin() && userData().orgId == data.orgId && userData().schoolId == data.schoolId); }

    // Perfiles de cuenta (rol + jugador vinculado). El uid del doc = uid de Firebase Auth.
    match /users/{uid} {
      allow read: if signedIn();
      // Al registrarse, cada uno crea su propio perfil pero NO puede nacer admin.
      // El admin sí puede crear perfiles de otros (p. ej. designar otro admin).
      allow create: if isAdmin() || (request.auth.uid == uid && request.resource.data.role == 'player');
      // Uno puede editar su propio perfil sin tocar rol ni jugador vinculado; el admin puede todo.
      allow update: if isAdmin() ||
        (request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.playerId == resource.data.playerId);
      allow delete: if isAdmin();
    }

    // Índice usuario→email (lectura pública: se necesita para loguear por usuario sin estar logueado).
    match /usernames/{uname} {
      allow read: if true;
      allow create: if isAdmin() || (signedIn() && request.resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // Jugadores: lectura para usuarios logueados; escritura del propio jugador (su perfil) o de un
    // admin de SU misma escuela (el superadmin, cualquiera). Un admin de otra escuela no puede tocarlo.
    match /players/{id} {
      allow read: if signedIn();
      allow create: if canManageSchool(request.resource.data) || myPlayerId() == id;  // alta por admin de la escuela o autoregistro (su propio doc)
      allow update: if canManageSchool(resource.data) || myPlayerId() == id;
      allow delete: if canManageSchool(resource.data);
    }

    // Gimnasios: solo admin escribe.
    match /gyms/{id}   { allow read: if signedIn(); allow write: if isAdmin(); }
    // Noticias: lectura para logueados (los borradores se filtran en la app); solo admin escribe.
    match /news/{id}   { allow read: if signedIn(); allow write: if isAdmin(); }
    // Ajustes (incluye el tema): lectura pública para poder pintar la apariencia publicada en
    // la pantalla de inicio sin estar logueado. No hay datos sensibles (colores + toggles).
    match /app/{doc}   { allow read: if true; allow write: if isAdmin(); }

    // Torneos: escribe el admin o un colaborador (su playerId está en collaborators).
    match /tournaments/{id} {
      allow read: if signedIn();
      allow write: if isAdmin() || (signedIn() && myPlayerId() in resource.data.collaborators);
      allow create: if isAdmin();
    }

    // Cuentas de cobro (MercadoPago): el token es SECRETO. Solo el admin dueño puede leer/escribir
    // las suyas (las consultas de la app van scopeadas por ownerUid). Los jugadores no acceden.
    // El backend (Cloudflare Worker) usa el Admin SDK y saltea estas reglas para crear el pago.
    match /payAccounts/{id} {
      allow read:   if isAdmin() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAdmin() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAdmin() && resource.data.ownerUid == request.auth.uid;
    }

    // Historial de pagos: lo escribe SOLO el backend (Worker, vía Admin SDK, que saltea reglas).
    // Desde el cliente: lo leen los admins (la app filtra por escuela/organización); nadie lo escribe.
    match /payments/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
