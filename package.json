    "url": "https://github.com/FranciscoDoti/tenis-mesa-app/issues"
  },
  "homepage": "https://github.com/FranciscoDoti/tenis-mesa-app#readme",
  "dependencies": {
    "firebase-admin": "^14.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.9"
  }
}
