{
  "name": "tenis-mesa-app",
  "version": "1.0.0",
  "description": "App web para administrar el tenis de mesa local: ranking por categorías, jugadores, torneos con reglas y armado automático de grupos. Roles **administrador** (gestiona todo) y **jugador** (solo ve).",
  "main": "app.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://FranciscoDoti@github.com/FranciscoDoti/tenis-mesa-app.git"
  },
